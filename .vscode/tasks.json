{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: build image",
      "type": "shell",
      "command": "docker build -t lab3-arm-builder .",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "docker: compile firmware",
      "type": "shell",
      "command": "bash scripts/docker-build.sh",
      "dependsOn": "docker: build image",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": {
        "owner": "arm-gcc",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "docker: shell",
      "type": "shell",
      "command": "bash scripts/docker-shell.sh",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "docker run --rm -v \"$(pwd)\":/work lab3-arm-builder make clean",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "flash",
      "type": "shell",
      "command": "bash scripts/flash.sh",
      "dependsOn": "docker: compile firmware",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    }
  ]
}
