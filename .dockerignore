# Keep the build context small and the image clean.
# Anything listed here is NOT sent to the Docker daemon when building the image.

# Version control and editor metadata
.git
.gitignore
.vscode
.devcontainer

# Documentation and CI — not needed to compile firmware
docs
.github
README.md

# Build outputs — these are generated inside the container, never copied in
output
*.o
*.elf
*.bin
*.hex
*.map
*.d
